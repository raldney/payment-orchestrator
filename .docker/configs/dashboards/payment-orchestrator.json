        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "panels": [],
      "title": "💰 Business KPIs - Volume Financeiro",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 101,
      "title": "Total Invoices Criadas",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(max_over_time(payment_invoices_created_total[$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 102,
      "title": "Volume Gerado (BRL)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(max_over_time(payment_invoices_amount_cents_total[$__range])) / 100 or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyBRL"
        }
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 103,
      "title": "Pagamentos Processados",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(max_over_time(payment_processed_total[$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 104,
      "title": "Taxa de Sucesso Transferência",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(max_over_time(payment_transfers_executed_total[$__range])) / sum(max_over_time(payment_processed_total[$__range])) * 100 or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 400,
      "panels": [],
      "title": "⏲️ Automation & Scheduling",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "id": 401,
      "title": "Próxima Geração de Invoices",
      "type": "stat",
      "targets": [
        {
          "expr": "max(payment_invoices_next_run_timestamp_seconds) * 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 6
      },
      "id": 402,
      "title": "Fim do Ciclo de Vida (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "max(payment_worker_lifecycle_end_timestamp_seconds) * 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 6
      },
      "id": 403,
      "title": "Status do Agendador",
      "type": "stat",
      "targets": [
        {
          "expr": "max({__name__=~\"payment_scheduler_status.*\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "index": 0,
                  "text": "OFF"
                },
                "1": {
                  "color": "green",
                  "index": 1,
                  "text": "ON"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value"
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "id": 1,
      "panels": [],
      "title": "📈 API & Infrastructure",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 11
      },
      "id": 3,
      "title": "API Request Volume (RPM)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate({__name__=~\"http_server_duration(_seconds|_milliseconds)?_count\"}[$__rate_interval])) by (url) * 60",
          "legendFormat": "{{url}}"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 11
      },
      "id": 5,
      "title": "Request Latency (P95 & P99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate({__name__=~\"http_server_duration(_seconds|_milliseconds)?_bucket\"}[$__rate_interval])) by (le, url))",
          "legendFormat": "{{url}} (p95)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate({__name__=~\"http_server_duration(_seconds|_milliseconds)?_bucket\"}[$__rate_interval])) by (le, url))",
          "legendFormat": "{{url}} (p99)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "id": 200,
      "panels": [],
      "title": "🌐 API Control Plane",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 20
      },
      "id": 202,
      "title": "API Error Events",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".*api.*\"} | json | level=~\"ERROR|CRITICAL\" [$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "gridPos": {
        "h": 10,
        "w": 18,
        "x": 6,
        "y": 20
      },
      "id": 201,
      "title": "Logs da API",
      "type": "logs",
      "targets": [
        {
          "expr": "{container=~\".*api.*\"} | json | service_component=\"api\" | level=~\"(?i)($service_level)\" | __error__=\"\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending"
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "id": 300,
      "panels": [],
      "title": "⚙️ Worker Background Processing",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 31
      },
      "id": 302,
      "title": "Worker Error Events",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\".*worker.*\"} | json | level=~\"ERROR|CRITICAL\" [$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "gridPos": {
        "h": 10,
        "w": 18,
        "x": 6,
        "y": 31
      },
      "id": 301,
      "title": "Logs do Worker",
      "type": "logs",
      "targets": [
        {
          "expr": "{container=~\".*worker.*\"} | json | service_component=\"worker\" | level=~\"(?i)($service_level)\" | __error__=\"\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "label": "Log Level",
        "name": "service_level",
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": "$__all"
          },
          {
            "selected": false,
            "text": "INFO",
            "value": "INFO"
          },
          {
            "selected": false,
            "text": "WARNING",
            "value": "WARNING"
          },
          {
            "selected": false,
            "text": "ERROR",
            "value": "ERROR"
          },
          {
            "selected": false,
            "text": "CRITICAL",
            "value": "CRITICAL"
          }
        ],
        "query": "INFO,WARNING,ERROR,CRITICAL",
        "type": "custom"
      }
    ]
  },
