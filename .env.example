# StarkBank Credentials (Sandbox)
STARK_PROJECT_ID=<your-starkbank-project-id>
STARK_PRIVATE_KEY="<your-ec-private-key-pem-contents>"
STARK_ENVIRONMENT=sandbox

# App Server
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=payment_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/payment_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis (result backend) & RabbitMQ (broker)
REDIS_URL=redis://redis:6379/0
RABBITMQ_USER=payment
RABBITMQ_PASS=payment
RABBITMQ_URL=amqp://payment:payment@rabbitmq:5672/payment
CELERY_BROKER_URL=amqp://payment:payment@rabbitmq:5672/payment
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Worker & Tasks
WORKER_MAX_TASKS_PER_CHILD=1000
WEBHOOK_MAX_RETRIES=10
BILLING_MAX_RETRIES=5
BOOTSTRAP_LOCK_TTL=60

# Observability
LOG_LEVEL=INFO
DEBUG=false
OTEL_ENABLED=true
OTEL_ENDPOINT=http://otel-collector:4317
OTEL_EXPORT_TIMEOUT=10
OTEL_BATCH_MAX_QUEUE_SIZE=2048
OTEL_BATCH_EXPORT_SIZE=512
OTEL_BATCH_DELAY_MS=5000

# App Settings
GENERATE_INVOICES_ENABLED=true
BATCH_SIZE_MIN=8
BATCH_SIZE_MAX=12
BATCH_AMOUNT_MIN=1000
BATCH_AMOUNT_MAX=100000

# Intervalo de faturamento (usar um dos dois, minutos tem prioridade no código)
BATCH_INTERVAL_MINUTES=30
BATCH_INTERVAL_HOURS=0
LIFECYCLE_HOURS=24
INVOICE_DUE_HOURS=24

# Fixed Sandbox Account for Transfers
SANDBOX_TAX_ID=20.018.183/0001-80
SANDBOX_BANK_CODE=20018183
SANDBOX_BRANCH_CODE=0001
SANDBOX_ACCOUNT_NUMBER=6341320293482496
SANDBOX_ACCOUNT_TYPE=payment
